{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@indigold/shared": ["packages/shared/src/index.ts"],
      "@indigold/shared/*": ["packages/shared/src/*"],
      "@indigold/db": ["packages/db/src/index.ts"]
    }
  },
  "include": [
    "packages/shared/src",
    "packages/db/src",
    "apps/api/src",
    "apps/worker/src",
    "apps/scheduler/src",
    "services/radian/src",
    "services/encompass/src"
  ]
}
