# Indigold local development env. Copy per-service or export in your shell.
# In production these are injected by render.yaml (see README).

# --- API (apps/api) ---
NODE_ENV=development
PORT=7000
DATABASE_URL=postgres://localhost:5432/indigold
REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=dev-session-secret-change-me
INTERNAL_TOKEN=dev-internal-token
RADIAN_URL=localhost:7101
ENCOMPASS_URL=localhost:7102
PWA_ORIGIN=http://localhost:3000
DAILY_TOKEN_BUDGET=200000
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60

# --- File upload / object storage (S3-compatible; Cloudflare R2 default) ---
# PRIVATE bucket only. Files are served via short-lived signed URLs.
# For Cloudflare R2: STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com, region=auto
# For AWS S3: omit STORAGE_ENDPOINT, set the real region. For MinIO/Supabase: set STORAGE_FORCE_PATH_STYLE=true.
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_SIGNED_URL_TTL=900
UPLOAD_MAX_BYTES=52428800
# DO NOT SET in production — its presence trips the public-write guard and refuses uploads:
# STORAGE_PUBLIC_BASE_URL=

# --- Worker (apps/worker) ---
# DATABASE_URL / REDIS_URL / RADIAN_URL (as above)

# --- Scheduler (apps/scheduler) ---
# DATABASE_URL / REDIS_URL
# SCHEDULER_TASK=auto   # auto | daily | weekly | monitor

# --- Private services (services/radian, services/encompass) ---
# PORT is auto-assigned on Render; INTERNAL_TOKEN must match the API's.

# --- PWA (apps/pwa) ---
# Leave VITE_API_URL empty to run standalone on bundled fixtures.
VITE_API_URL=
